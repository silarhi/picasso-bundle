{
    "extensions": ["gd", "pcov"],
    "exclude": [
        {
            "name": "README Linting"
        }
    ],
    "ignore_php_platform_requirements": {
        "8.4": true,
        "8.5": true
    },
    "additional_checks": [
        {
            "name": "Composer validate & normalize",
            "job": {
                "php": "@lowest",
                "dependencies": "latest",
                "command": "composer validate --strict && composer normalize --dry-run --diff"
            }
        }
    ]
}
