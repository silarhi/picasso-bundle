{% set userStyle = attributes.all.style|default('') %}
{% set blurStyle = this.placeholderUri ? 'background-size:cover;background-position:center;background-repeat:no-repeat;background-image:url(' ~ this.placeholderUri ~ ');' : '' %}
{% set fullStyle = blurStyle ~ userStyle %}

{% if this.fallbackSrc %}
    {% if this.unoptimized or this.sources is empty %}
        <img
            src="{{ this.fallbackSrc }}"
            {% if this.fallbackSrcset %}srcset="{{ this.fallbackSrcset }}"{% endif %}
            {% if this.sizes %}sizes="{{ this.sizes }}"{% endif %}
            {% if this.width and this.height %}width="{{ this.width }}" height="{{ this.height }}"{% endif %}
            loading="{{ this.loading }}"
            {% if this.fetchPriority %}fetchpriority="{{ this.fetchPriority }}"{% endif %}
            {% if fullStyle %}style="{{ fullStyle }}"{% endif %}
            {% if this.placeholderUri %}onload="this.style.backgroundImage=''"{% endif %}
            {{ attributes.without('style') }}
        />
    {% else %}
        <picture>
            {% for source in this.sources %}
                <source
                    type="{{ source.type }}"
                    srcset="{{ source.srcset }}"
                    {% if this.sizes %}sizes="{{ this.sizes }}"{% endif %}
                />
            {% endfor %}

            <img
                src="{{ this.fallbackSrc }}"
                srcset="{{ this.fallbackSrcset }}"
                {% if this.sizes %}sizes="{{ this.sizes }}"{% endif %}
                {% if this.width and this.height %}width="{{ this.width }}" height="{{ this.height }}"{% endif %}
                loading="{{ this.loading }}"
                {% if this.fetchPriority %}fetchpriority="{{ this.fetchPriority }}"{% endif %}
                {% if fullStyle %}style="{{ fullStyle }}"{% endif %}
                {% if this.placeholderUri %}onload="this.style.backgroundImage=''"{% endif %}
                {{ attributes.without('style') }}
            />
        </picture>
    {% endif %}
{% endif %}
