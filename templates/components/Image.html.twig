{% if this.fallbackSrc %}
    {% if this.unoptimized or (this.sources is empty and not this.fallbackSrcset) %}
        <img
            src="{{ this.fallbackSrc }}"
            {% if this.width %}width="{{ this.width }}"{% endif %}
            {% if this.height %}height="{{ this.height }}"{% endif %}
            loading="{{ this.loading }}"
            {% if this.fetchPriority %}fetchpriority="{{ this.fetchPriority }}"{% endif %}
            {{ attributes }}
        />
    {% else %}
        <picture>
            {% for source in this.sources %}
                <source
                    type="{{ source.type }}"
                    srcset="{{ source.srcset }}"
                    {% if this.sizes %}sizes="{{ this.sizes }}"{% endif %}
                />
            {% endfor %}

            {% set userStyle = attributes.all.style|default('') %}
            {% set blurStyle = this.blurDataUri ? 'background-size:cover;background-position:center;background-repeat:no-repeat;background-image:url(' ~ this.blurDataUri ~ ');' : '' %}
            {% set fullStyle = blurStyle ~ userStyle %}

            <img
                src="{{ this.fallbackSrc }}"
                srcset="{{ this.fallbackSrcset }}"
                {% if this.sizes %}sizes="{{ this.sizes }}"{% endif %}
                {% if this.width %}width="{{ this.width }}"{% endif %}
                {% if this.height %}height="{{ this.height }}"{% endif %}
                loading="{{ this.loading }}"
                {% if this.fetchPriority %}fetchpriority="{{ this.fetchPriority }}"{% endif %}
                {% if fullStyle %}style="{{ fullStyle }}"{% endif %}
                {% if this.blurDataUri %}onload="this.style.backgroundImage=''"{% endif %}
                {{ attributes.without('style') }}
            />
        </picture>
    {% endif %}
{% endif %}
